DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trainingzone?schema=public"

# NextAuth
AUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Microsoft Entra ID (Azure AD) - preparado para producción, NO activo por defecto.
# Rellenar con los valores del App Registration en Azure Portal para habilitar
# el login corporativo con Microsoft. Con estas tres vacías, solo se usa el
# login demo (Credentials) contra los usuarios sembrados por prisma/seed.ts.
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# Google OAuth - preparado para producción, NO activo por defecto (igual que
# Microsoft). Rellenar con las credenciales OAuth de Google Cloud Console para
# habilitar el login con Google. Con estas dos vacías, el botón no se activa.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe (cobros) - preparado para producción, NO activo por defecto. Rellenar
# con las claves de la cuenta Stripe real para habilitar el checkout de pagos
# y la conciliación por webhook. Con estas vacías, el botón de cobro por
# Stripe muestra un error controlado en vez de fallar.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron de reglas de negocio (/api/jobs/run) - secreto compartido con el
# disparador externo (Vercel Cron u otro) que llama a esa ruta periódicamente.
# Si se deja vacío, la ruta acepta llamadas sin autenticar (solo válido en
# desarrollo).
JOBS_CRON_SECRET=""

# SMTP (email transaccional: invitaciones, altas...) - preparado para
# producción, NO activo por defecto. Rellenar con las credenciales de
# cualquier proveedor compatible con SMTP (Resend, SES, Postmark, Sendgrid...)
# para que los emails se envíen de verdad. Con estas vacías, el envío se
# simula registrando el email en el log del servidor.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
