// TRAINING ZONE — modelo de datos multi-tenant (ADR-003/004)
// Aislamiento por organización vía orgId ("tenant_id") en cada tabla de negocio.
// En producción sobre Postgres real se añadiría Row Level Security (ADR-004);
// aquí el aislamiento se aplica en la capa de acceso a datos (lib/tenant.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- Tenancy ----------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String? // logo de marca para el NavBar; si es null se usa el de Apta
  createdAt DateTime @default(now())

  centers       Center[]
  users         User[]
  members       Member[]
  plans         MembershipPlan[]
  sessions      ClassSession[]
  templates     SessionTemplate[]
  payments      Payment[]
  auditLogs     AuditLog[]
  aptitudeRules AptitudeRule[]
  centerMemberships CenterMembership[]
  memberNotes       MemberNote[]
  invitations       Invitation[]

  leads                  Lead[]
  leadNotes              LeadNote[]
  leadChannels           LeadChannel[]
  noCloseReasons         NoCloseReason[]
  clientGoals            ClientGoal[]
  notifications          Notification[]
  workoutPrograms        WorkoutProgram[]
  selfAssessments        SelfAssessment[]
  conversations          Conversation[]
  timeClockEntries       TimeClockEntry[]
  staffProposals         StaffProposal[]
  personalizedOffers     PersonalizedOffer[]
  trainerRatings         TrainerRating[]
  checkinScheduleConfigs CheckinScheduleConfig[]
  referenceRanges        ReferenceRange[]
}

model Center {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  slug      String
  address   String?
  logoUrl   String? // logo propio del centro; si es null se hereda el de la organización (y en su defecto, Apta)
  timezone  String   @default("Europe/Madrid")
  createdAt DateTime @default(now())

  organization Organization      @relation(fields: [orgId], references: [id])
  users        User[]
  members      Member[]          @relation("PrimaryCenter")
  templates    SessionTemplate[]
  sessions     ClassSession[]
  staffMemberships CenterMembership[]
  leads            Lead[]
  timeClockEntries TimeClockEntry[]

  @@unique([orgId, slug])
  @@index([orgId])
}

// ---------- Identidad y roles ----------

enum Role {
  PLATFORM_ADMIN
  OWNER
  CENTER_DIRECTOR
  TRAINER
  RECEPTION
  MEMBER
  HR_MANAGER // RRHH: gestiona personal e imputación a centros, sin acceso a datos de salud
}

model User {
  id           String   @id @default(cuid())
  orgId        String
  centerId     String?
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  image        String?
  authProvider String   @default("demo") // "demo" | "microsoft-entra-id" (preparado, no activo)
  createdAt    DateTime @default(now())

  organization        Organization      @relation(fields: [orgId], references: [id])
  center               Center?           @relation(fields: [centerId], references: [id])
  trainerSessions      ClassSession[]    @relation("TrainerSessions")
  trainerTemplates     SessionTemplate[] @relation("TrainerTemplates")
  memberProfile        Member?           @relation("MemberUser")
  auditLogs            AuditLog[]
  healthReported       HealthRecord[]    @relation("ReportedBy")
  aptitudeRulesEdited  AptitudeRule[]    @relation("EditedBy")
  referenceRangesEdited ReferenceRange[] @relation("EditedReferenceRange")
  centerMemberships    CenterMembership[]
  memberNotesAuthored  MemberNote[]      @relation("MemberNoteAuthor")
  invitation           Invitation?

  leadsOwned            Lead[]              @relation("LeadOwner")
  leadNotesAuthored     LeadNote[]          @relation("LeadNoteAuthor")
  assignedMembers       Member[]            @relation("AssignedMemberTrainer")
  directedSessions      ClassSession[]      @relation("DirectedSessions")
  workoutProgramsConfirmed WorkoutProgram[] @relation("WorkoutConfirmedBy")
  notifications         Notification[]      @relation("NotificationRecipient")
  timeClockEntries      TimeClockEntry[]
  staffProposalsAuthored StaffProposal[]
  offersProposed        PersonalizedOffer[] @relation("OfferProposedBy")
  offersApproved        PersonalizedOffer[] @relation("OfferApprovedBy")
  trainerRatingsReceived TrainerRating[]    @relation("TrainerRatingSubject")
  paymentsSold          Payment[]           @relation("SoldBy")
  chatMessagesSent      ChatMessage[]

  @@index([orgId])
}

// ---------- Invitaciones (F7 self-service + alta de personal/socios) ----------
// Token de un solo uso para que personal y socios creen su contraseña
// (personal) o contraseña + consentimientos (socios). Caduca a los 7 días
// (RB descrita en el handoff). Sin backend de email real en esta demo: el
// enlace se registra vía lib/mailer.ts (log de servidor).

enum InvitationType {
  STAFF
  MEMBER
}

model Invitation {
  id        String         @id @default(cuid())
  orgId     String
  type      InvitationType
  token     String         @unique
  email     String
  userId    String?        @unique
  memberId  String?        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  member       Member?      @relation(fields: [memberId], references: [id])

  @@index([orgId])
  @@index([expiresAt])
}

// Imputación de personal a centros: relación N:N staff ↔ centro con un rol y un
// % de dedicación por centro. Permite que una persona trabaje en varios centros
// con roles distintos; `User.role`/`User.centerId` quedan como rol y centro base
// (retrocompatibilidad). El ámbito efectivo se resuelve contra esta tabla.
model CenterMembership {
  id            String    @id @default(cuid())
  orgId         String
  userId        String
  centerId      String
  role          Role
  isPrimary     Boolean   @default(false)
  allocationPct Int? // % de jornada imputado a este centro (0-100)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  createdAt     DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  center       Center       @relation(fields: [centerId], references: [id])

  @@unique([userId, centerId])
  @@index([orgId])
  @@index([centerId])
  @@index([userId])
}

// ---------- Socio y catálogo comercial (A.2.1) ----------

enum MemberState {
  PROSPECT
  TRIAL
  ACTIVE
  DELINQUENT
  FROZEN
  CANCELLED
}

// Sexo del socio (columna "Sexo" del export externo: Mujer/Hombre/Otro).
enum Sex {
  FEMALE
  MALE
  OTHER
}

// Riesgo de abandono heredado del export (MyWellness "Riesgo de abandono":
// Baja/Media/Alta). Es la señal del sistema de origen; el motor de retención
// propio (G.3) sigue calculando su RetentionAlert por separado.
enum ChurnRisk {
  LOW
  MEDIUM
  HIGH
}

model Member {
  id                 String      @id @default(cuid())
  orgId              String
  primaryCenterId    String
  userId             String?     @unique
  firstName          String
  lastName           String
  email              String
  phone              String?
  birthDate          DateTime?
  address            String?
  emergencyContact   String?
  photoUrl           String? // foto de perfil (subida como data URL en esta demo)
  state              MemberState @default(PROSPECT)
  joinedAt           DateTime    @default(now())
  cancelledAt        DateTime?
  consentContract    Boolean     @default(true)
  consentHealth      Boolean     @default(false)
  consentImages      Boolean     @default(false) // uso de imágenes (fotos de evolución)
  consentMarketing   Boolean     @default(false)
  consentContractAt  DateTime?
  consentHealthAt    DateTime?
  consentImagesAt    DateTime?
  consentMarketingAt DateTime?
  consentVersion     String? // versión del texto legal firmado en el onboarding
  notes              String?
  createdAt          DateTime    @default(now())

  // RB-PERFIL: perfil extendido (F9) — CP/ocupación/canal heredados del lead de origen,
  // entrenador responsable explícito (EP y online; null = responsable Training Zone).
  postalCode     String?
  occupation     String?
  hasChildren    Boolean? // BI demográfico (RB-BI-003), heredado del lead si se respondió
  channel        String?
  heightCm       Int? // composición corporal: base para IMC/rangos de referencia (docs/COMPOSICION_CORPORAL_*)
  originLeadId   String? @unique
  trainerId      String?
  stripeCustomerId String? @unique // F12 (RB-PAGO-001): cliente Stripe para cobros recurrentes

  // --- Importación de socios desde export externo (F-IMPORT / RB-IMPORT) ---
  // El director puede importar un CSV de socios exportado de otra plataforma
  // (p.ej. MyWellness/Technogym). Estos campos capturan las columnas del export
  // que no encajaban en el perfil base. `externalRef` (el "Identificador de la
  // nube" del origen) es la clave estable que hace la reimportación idempotente:
  // volver a subir el mismo CSV actualiza al socio en vez de duplicarlo.
  sex                 Sex?
  addressLine2        String? // "Dirección 2" (la línea 1 va a `address`)
  city                String?
  province            String?
  country             String?
  churnRisk           ChurnRisk? // "Riesgo de abandono" del origen
  primaryAspiration   String? // "Aspiración principal" (Move/Shape/Power/Sport/Balance/Fun)
  secondaryAspiration String? // "Aspiración secundaria"
  lastAccessAt        DateTime? // "Último acceso"
  lastInteractionAt   DateTime? // "Última interacción"
  accountCreatedAt    DateTime? // "Fecha de creación de la cuenta"
  mywellnessAccount   String? // "Cuenta mywellness" (login del socio en el origen)
  externalId          String? // "ID externo" del sistema de origen
  externalSource      String? // procedencia del registro ("mywellness" | ...)
  externalRef         String? // "Identificador de la nube" — clave de idempotencia de la importación

  organization    Organization           @relation(fields: [orgId], references: [id])
  primaryCenter   Center                 @relation("PrimaryCenter", fields: [primaryCenterId], references: [id])
  user            User?                  @relation("MemberUser", fields: [userId], references: [id])
  trainer         User?                  @relation("AssignedMemberTrainer", fields: [trainerId], references: [id])
  originLead      Lead?                  @relation("MemberOriginLead", fields: [originLeadId], references: [id])
  subscriptions   Subscription[]
  bookings        Booking[]
  payments        Payment[]
  healthRecords   HealthRecord[]
  retentionAlerts RetentionAlert[]
  noteEntries     MemberNote[]
  progressEntries MemberProgressEntry[]
  invitation      Invitation?
  convertedFromLead Lead?                @relation("LeadConvertedMember")
  clientGoals     ClientGoal[]
  workoutPrograms WorkoutProgram[]
  selfAssessments SelfAssessment[]
  conversation    Conversation?
  personalizedOffers PersonalizedOffer[]
  trainerRatingsGiven TrainerRating[]

  @@unique([orgId, externalRef]) // idempotencia de la importación por socio del origen
  @@index([orgId])
  @@index([primaryCenterId])
  @@index([state])
  @@index([trainerId])
}

// Fotos y métricas de evolución física (Ficha Socio). Visibles solo para el
// socio y su entrenador asignado (mismo ámbito que health-access).
model MemberProgressEntry {
  id            String   @id @default(cuid())
  memberId      String
  date          DateTime @default(now())
  weightKg      Float?
  bodyFatPct    Float?
  waistCm       Float?
  photoFrontUrl String?
  photoSideUrl  String?
  photoBackUrl  String?
  createdAt     DateTime @default(now())

  // Composición corporal (bioimpedancia, p.ej. Tanita) — docs/COMPOSICION_CORPORAL_TANITA.md §3.
  // Todos opcionales: una fila puede seguir siendo un registro "solo peso/fotos" como hasta ahora.
  // Dato Art. 9 RGPD (RB-PERFIL-004): mismo tratamiento que HealthRecord, ver lib/health-access.ts.
  muscleMassKg      Float? // masa muscular
  fatMassKg         Float? // masa grasa (kg)
  fatFreeMassKg     Float? // masa magra / libre de grasa
  bodyWaterPct      Float? // agua corporal (%)
  boneMassKg        Float? // masa ósea
  visceralFatRating Int? // grasa visceral (rating Tanita, no %)
  muscleQuality     Int? // "calidad muscular" (MQ Tanita)
  bmrKcal           Int? // metabolismo basal
  metabolicAge      Int? // edad metabólica
  bmi               Float? // IMC (se guarda además de derivarse, para no depender de heightCm al recalcular históricos)
  segmental         Json? // análisis por segmento: tronco/brazos/piernas {fatPct, muscleKg}
  source            String    @default("MANUAL") // "MANUAL" | "TANITA" (pegado desde MyTanita)
  measuredAt        DateTime? // fecha real de la toma (≠ createdAt), relevante en importaciones

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
}

// Rangos de referencia de composición corporal (RB-PERFIL-004 / semáforo en la ficha del socio).
// Tabla editable por dirección — no hardcode — misma filosofía que AptitudeRule.
model ReferenceRange {
  id     String  @id @default(cuid())
  orgId  String
  metric String // "bodyFatPct" | "bmi" | "visceralFatRating" | "bodyWaterPct" ...
  sex    String? // null = aplica a ambos
  ageMin Int?
  ageMax Int?
  min    Float?
  max    Float?

  editedByUserId String?
  updatedAt      DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  editedBy     User?        @relation("EditedReferenceRange", fields: [editedByUserId], references: [id])

  @@index([orgId])
  @@index([orgId, metric])
}

// Bitácora de comentarios internos del socio (RB-LEAD-008): lista cronológica
// "nota + autor + fecha", DISTINTA de los datos clínicos de HealthRecord. No es
// dato del Art. 9 RGPD, así que la ve cualquier rol de staff (no pasa por
// health-access). Lo clínico va siempre a HealthRecord.
model MemberNote {
  id           String   @id @default(cuid())
  orgId        String
  memberId     String
  authorUserId String?
  body         String
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])
  author       User?        @relation("MemberNoteAuthor", fields: [authorUserId], references: [id])

  @@index([orgId])
  @@index([memberId])
}

// Objetivos concretos de salud/rendimiento del socio (RB-PERFIL-003). Catálogo
// editable por dirección: las filas con isTemplate=true son el catálogo de
// partida (sin memberId real, se clonan al asignar), las demás son objetivos
// asignados a un socio concreto.
model ClientGoal {
  id String @id @default(cuid())
  orgId String
  memberId String? // null en filas de catálogo (isTemplate=true)
  label String
  isTemplate Boolean @default(false)
  achievedAt DateTime?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  member Member? @relation(fields: [memberId], references: [id])

  @@index([orgId])
  @@index([memberId])
}

enum PlanType {
  MONTHLY
  SESSION_PACK
  DROP_IN
  PERSONAL_TRAINING
  DUO
  ONLINE
}

model MembershipPlan {
  id               String   @id @default(cuid())
  orgId            String
  name             String
  type             PlanType
  sessionsIncluded Int?
  priceCents       Int
  validityDays     Int?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  organization  Organization   @relation(fields: [orgId], references: [id])
  subscriptions Subscription[]

  @@index([orgId])
}

enum SubscriptionStatus {
  ACTIVE
  FROZEN
  CANCELLED
  EXPIRED
}

model Subscription {
  id                String             @id @default(cuid())
  memberId          String
  planId            String
  startDate         DateTime
  endDate           DateTime?
  status            SubscriptionStatus @default(ACTIVE)
  priceCents        Int
  sessionsRemaining Int?
  createdAt         DateTime           @default(now())

  member   Member         @relation(fields: [memberId], references: [id])
  plan     MembershipPlan @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([memberId])
}

// ---------- Agenda y reservas (A.2.2) ----------

model SessionTemplate {
  id          String   @id @default(cuid())
  orgId       String
  centerId    String
  name        String
  classType   String
  weekday     Int // 0=domingo .. 6=sábado
  startTime   String // "HH:mm"
  durationMin Int
  capacity    Int
  room        String?
  trainerId   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  organization Organization   @relation(fields: [orgId], references: [id])
  center       Center         @relation(fields: [centerId], references: [id])
  trainer      User?          @relation("TrainerTemplates", fields: [trainerId], references: [id])
  sessions     ClassSession[]

  @@index([orgId])
  @@index([centerId])
}

enum SessionStatus {
  SCHEDULED
  CANCELLED
}

model ClassSession {
  id         String        @id @default(cuid())
  orgId      String
  centerId   String
  templateId String?
  name       String
  classType  String
  date       DateTime // fecha (medianoche) del día de la sesión
  startTime  String // "HH:mm"
  endTime    String // "HH:mm"
  capacity   Int
  room       String?
  trainerId  String?
  status     SessionStatus @default(SCHEDULED)
  createdAt  DateTime      @default(now())

  // RB-AGENDA-002/004: hueco de EP (classType="PERSONAL_TRAINING", capacity=1).
  // selfBookable distingue la franja abierta a autorreserva del cliente de EP
  // (RB-AGENDA-001/002) de la reservada a mano por el entrenador. directedByUserId
  // registra quién dirigió realmente la sesión (verificación cruzada F13/RB-RRHH-002),
  // que puede diferir del entrenador asignado en la plantilla.
  selfBookable     Boolean @default(false)
  directedByUserId String?

  // Rediseño de agenda estilo Google Calendar: recurrencia simple (una fila
  // representa toda la serie; las ocurrencias en otras semanas se derivan en
  // lectura a partir de `date`/`recurrence`/`recUntil`, sin materializarlas).
  recurrence SessionRecurrence @default(NONE)
  recUntil   DateTime?
  isTrial    Boolean           @default(false)

  organization Organization     @relation(fields: [orgId], references: [id])
  center       Center           @relation(fields: [centerId], references: [id])
  template     SessionTemplate? @relation(fields: [templateId], references: [id])
  trainer      User?            @relation("TrainerSessions", fields: [trainerId], references: [id])
  directedBy   User?            @relation("DirectedSessions", fields: [directedByUserId], references: [id])
  bookings     Booking[]

  @@index([orgId])
  @@index([centerId, date])
}

enum SessionRecurrence {
  NONE
  WEEKLY
  WEEKDAYS
}

enum BookingStatus {
  BOOKED
  WAITLISTED
  CANCELLED
  ATTENDED
  NO_SHOW
}

model Booking {
  id               String        @id @default(cuid())
  sessionId        String
  memberId         String
  status           BookingStatus @default(BOOKED)
  waitlistPosition Int?
  bookedAt         DateTime      @default(now())
  checkedInAt      DateTime?
  cancelledAt      DateTime?

  session ClassSession    @relation(fields: [sessionId], references: [id])
  member  Member          @relation(fields: [memberId], references: [id])
  debrief SessionDebrief?

  @@index([sessionId])
  @@index([memberId])
  @@index([status])
}

// ---------- Cobros (A.2.3) ----------

enum PaymentMethod {
  CASH
  CARD
  BIZUM
  TRANSFER
  SEPA
  STRIPE // F12/RB-PAGO-001: cobro online (checkout o domiciliación) conciliado por webhook
}

enum PaymentStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(cuid())
  orgId          String
  memberId       String
  subscriptionId String?
  amountCents    Int
  method         PaymentMethod
  status         PaymentStatus @default(PAID)
  date           DateTime
  receiptNumber  String?
  notes          String?
  soldByUserId   String? // RB-RRHH-004: venta atribuida a trabajador (ranking mensual)
  stripeCheckoutSessionId String? @unique // F12: sesión de checkout que originó el cobro
  stripePaymentIntentId   String? @unique // F12: PaymentIntent confirmado por el webhook
  createdAt      DateTime      @default(now())

  organization Organization  @relation(fields: [orgId], references: [id])
  member       Member        @relation(fields: [memberId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  soldBy       User?         @relation("SoldBy", fields: [soldByUserId], references: [id])

  @@index([orgId])
  @@index([memberId])
  @@index([date])
}

// ---------- Salud (A.2.4) — datos Art. 9 RGPD ----------
// Nota de diseño: en producción este modelo vive en un esquema separado
// (`health.*`, ADR-005) con cifrado a nivel de columna. En este entorno de
// demo se representa en el mismo esquema para simplificar, pero el acceso
// pasa siempre por lib/health-access.ts, que aplica la matriz de permisos
// y registra cada lectura en AuditLog (ADR-008).

enum HealthRecordType {
  INJURY
  CHRONIC_CONDITION
  MEDICATION
  SURGERY
  PREGNANCY
  ALLERGY
}

enum HealthSeverity {
  LOW
  MEDIUM
  HIGH
}

enum HealthStatus {
  ACTIVE
  RESOLVED
}

model HealthRecord {
  id               String           @id @default(cuid())
  // Dato Art. 9 RGPD: cuelga de un socio O de un lead (nunca ambos), para que al
  // convertir el lead (RB-LEAD-007) el registro solo cambie de FK y no se
  // recapture el dato. Todo acceso sigue pasando por lib/health-access.ts.
  memberId         String?
  leadId           String?
  type             HealthRecordType
  zone             String? // p.ej. "hombro derecho"
  description      String
  severity         HealthSeverity
  status           HealthStatus     @default(ACTIVE)
  reportedByUserId String?
  reportedAt       DateTime         @default(now())
  resolvedAt       DateTime?
  consentSignedAt  DateTime?

  member     Member? @relation(fields: [memberId], references: [id])
  lead       Lead?   @relation(fields: [leadId], references: [id])
  reportedBy User?   @relation("ReportedBy", fields: [reportedByUserId], references: [id])

  @@index([memberId])
  @@index([leadId])
  @@index([status])
}

// Semáforo de Aptitud (G.2): reglas deterministas mantenidas por Sergio,
// no por el modelo de IA. La IA (F6, fuera de esta entrega) solo redactaría.
enum AptitudeLight {
  GREEN
  AMBER
  RED
}

model AptitudeRule {
  id             String        @id @default(cuid())
  orgId          String
  injuryZone     String // coincide con HealthRecord.zone
  blockArea      String // p.ej. "Empuje vertical"
  light          AptitudeLight
  adaptation     String? // p.ej. "reducir ROM, carga <=60%"
  editedByUserId String?
  updatedAt      DateTime      @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  editedBy     User?        @relation("EditedBy", fields: [editedByUserId], references: [id])

  @@index([orgId])
}

// Session Debrief (G.1): captura post-sesión en <20s, un toque por persona.
enum DebriefFeeling {
  GREEN
  AMBER
  RED
}

model SessionDebrief {
  id        String         @id @default(cuid())
  bookingId String         @unique
  feeling   DebriefFeeling
  rpe       Int?
  note      String?
  createdAt DateTime       @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

// ---------- Auditoría append-only (ADR-008) ----------

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String
  actorUserId String?
  action      String // p.ej. "HEALTH_RECORD_READ", "MEMBER_UPDATED"
  entityType  String
  entityId    String
  memberId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  actor        User?        @relation(fields: [actorUserId], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([memberId])
}

// ---------- Motor de retención (G.3) ----------

enum RetentionRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum RetentionAlertStatus {
  OPEN
  CONTACTED
  POSTPONED
  DISMISSED
}

model RetentionAlert {
  id           String               @id @default(cuid())
  memberId     String
  baselineFreq Float // sesiones/semana, línea base personal
  recentFreq   Float // sesiones/semana, últimas 2 semanas
  dropPct      Float
  riskLevel    RetentionRiskLevel
  context      String?
  status       RetentionAlertStatus @default(OPEN)
  createdAt    DateTime             @default(now())
  resolvedAt   DateTime?

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([status])
}

// ---------- F8: Embudo de Leads / CRM comercial ----------

enum LeadStatus {
  SIN_CONTACTAR
  SEGUIMIENTO
  CON_FECHA_VALORACION
  CERRADO
  NO_CERRADO
}

// Canales de origen ("cómo nos conociste") configurables por dirección sin
// desplegar (RB-LEAD-004), misma filosofía que AptitudeRule.
model LeadChannel {
  id        String   @id @default(cuid())
  orgId     String
  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

// Motivos de no cierre configurables (RB-LEAD-011): obligatorio al pasar un
// lead a NO_CERRADO, editable por dirección sin desplegar.
model NoCloseReason {
  id        String   @id @default(cuid())
  orgId     String
  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model Lead {
  id               String     @id @default(cuid())
  orgId            String
  centerId         String
  firstName        String
  lastName         String
  phone            String // canal de reset por SMS (RB-LEAD-002)
  email            String? // condicional (RB-LEAD-002): teléfono o email, al menos uno
  postalCode       String // RB-LEAD-010: estructurado, no dirección libre
  occupation       String // alimenta BI nicho (RB-BI-003)
  hasChildren      Boolean? // BI demográfico (RB-BI-003), pregunta opcional
  goals            String
  hasTrainedBefore Boolean
  hasTrainedNote   String?
  channel          String // RB-LEAD-004: coincide con LeadChannel.label
  status           LeadStatus @default(SIN_CONTACTAR)
  ownerUserId      String? // responsable del contacto (RB-LEAD-003)
  contactedAt      DateTime   @default(now()) // fecha de contacto automática (RB-LEAD-001)
  noCloseReason    String?    // obligatorio al pasar a NO_CERRADO (RB-LEAD-011)
  convertedMemberId String?   @unique // enlace al Member creado si CERRADO (RB-LEAD-007)
  createdAt        DateTime   @default(now())

  organization    Organization   @relation(fields: [orgId], references: [id])
  center          Center         @relation(fields: [centerId], references: [id])
  owner           User?          @relation("LeadOwner", fields: [ownerUserId], references: [id])
  convertedMember Member?        @relation("LeadConvertedMember", fields: [convertedMemberId], references: [id])
  originForMember Member?        @relation("MemberOriginLead")
  notes           LeadNote[]
  healthRecords   HealthRecord[]

  @@index([orgId])
  @@index([centerId])
  @@index([status])
}

// Bitácora del lead (RB-LEAD-008), gemela de MemberNote pero para el embudo comercial.
model LeadNote {
  id           String   @id @default(cuid())
  orgId        String
  leadId       String
  authorUserId String?
  body         String
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  lead         Lead         @relation(fields: [leadId], references: [id])
  author       User?        @relation("LeadNoteAuthor", fields: [authorUserId], references: [id])

  @@index([orgId])
  @@index([leadId])
}

// ---------- F10: Notificaciones / tareas (transversal) ----------

enum NotificationKind {
  TASK
  ALERT
  INFO
}

model Notification {
  id              String           @id @default(cuid())
  orgId           String
  recipientUserId String
  kind            NotificationKind @default(TASK)
  title           String
  body            String?
  entityType      String? // "Lead" | "Member" | "PersonalizedOffer"...
  entityId        String?
  dueDate         DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  recipient    User         @relation("NotificationRecipient", fields: [recipientUserId], references: [id])

  @@index([orgId])
  @@index([recipientUserId])
  @@index([resolvedAt])
}

// ---------- F13: RRHH — fichaje y buzón de propuestas ----------

model TimeClockEntry {
  id        String    @id @default(cuid())
  orgId     String
  userId    String
  centerId  String
  workDate  DateTime
  clockIn   String // "HH:mm"
  clockOut  String?
  signedAt  DateTime? // firma digital de conformidad (RB-RRHH-001/002)
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  center       Center       @relation(fields: [centerId], references: [id])

  @@index([orgId])
  @@index([userId])
}

model StaffProposal {
  id           String   @id @default(cuid())
  orgId        String
  authorUserId String
  body         String
  status       String   @default("OPEN") // OPEN | REVIEWED
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  author       User         @relation(fields: [authorUserId], references: [id])

  @@index([orgId])
}

// ---------- F14: Motor de ofertas y valoración de entrenadores ----------

enum OfferStatus {
  SUGERIDA
  PENDIENTE_DIRECCION
  APROBADA
  RECHAZADA
  COMUNICADA
}

model PersonalizedOffer {
  id               String      @id @default(cuid())
  orgId            String
  memberId         String
  proposedByUserId String? // entrenador que la eleva
  approvedByUserId String? // dirección: luz verde obligatoria (RB-RRHH-013)
  signals          Json // señales que la dispararon (asistencia, antigüedad, RPE...)
  description      String // "2 días/semana con 20% dto. el primer mes", etc.
  status           OfferStatus @default(SUGERIDA)
  createdAt        DateTime    @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])
  proposedBy   User?        @relation("OfferProposedBy", fields: [proposedByUserId], references: [id])
  approvedBy   User?        @relation("OfferApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([orgId])
  @@index([memberId])
}

// Valoración CONFIDENCIAL del entrenador por el socio (RB-RRHH-011/012): el
// acceso se centraliza en lib/trainer-rating-access.ts, que solo deja leer a
// dirección — nunca al propio entrenador, ni sobre sí mismo (matriz invertida
// respecto a health-access.ts).
model TrainerRating {
  id            String   @id @default(cuid())
  orgId         String
  trainerUserId String
  memberId      String // quién valora (no visible al entrenador)
  score         Int?
  strengths     String?
  improvements  String?
  createdAt     DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  trainer      User         @relation("TrainerRatingSubject", fields: [trainerUserId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])

  @@index([orgId])
  @@index([trainerUserId])
}

// ---------- F15: Programador de check-ins periódicos ----------

enum ServiceKind {
  GROUP
  PERSONAL_TRAINING
  ONLINE
}

// Intervalos configurables por org x tipo de servicio (decisión §11.6, defaults
// mensual/trimestral) para el check-in de objetivos (RB-IA-006) y la valoración
// de entrenadores (RB-RRHH-011). El programador de F10 emite las
// SelfAssessment/TrainerRating cuando corresponde.
model CheckinScheduleConfig {
  id                String      @id @default(cuid())
  orgId             String
  serviceKind       ServiceKind
  goalCheckinDays   Int         @default(30)
  trainerRatingDays Int         @default(90)
  updatedAt         DateTime    @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, serviceKind])
  @@index([orgId])
}

// ---------- F16: IA de programación, autovaloración y chat ----------

enum WorkoutProgramStatus {
  DRAFT
  PENDING_TRAINER
  ACTIVE
  COMPLETED
}

// Rutina generada por IA con confirmación humana obligatoria (RB-IA-001/003):
// el agente solo propone (createdByAI), un entrenador siempre confirma antes
// de que pase a ACTIVE (RB-IA-002: uso solo por staff).
model WorkoutProgram {
  id                String                @id @default(cuid())
  orgId             String
  memberId          String
  createdByAI       Boolean               @default(true)
  confirmedByUserId String?
  status            WorkoutProgramStatus  @default(DRAFT)
  payload           Json
  createdAt         DateTime              @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])
  confirmedBy  User?        @relation("WorkoutConfirmedBy", fields: [confirmedByUserId], references: [id])

  @@index([orgId])
  @@index([memberId])
}

// Autovaloración del cliente (RB-IA-005) y check-in periódico de objetivos
// (RB-IA-006): la recomendación de IA se guarda junto a la respuesta para
// trazabilidad, con confirmación humana siempre presente aguas abajo.
model SelfAssessment {
  id               String   @id @default(cuid())
  orgId            String
  memberId         String
  kind             String // "mensual" | "estancamiento" | "check-in objetivos"
  text             String?
  structured       Json?
  aiRecommendation String?
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])

  @@index([orgId])
  @@index([memberId])
}

// Chat centro-cliente (RB-CHAT-001): visibilidad limitada al entrenador
// asignado + dirección; la IA puede escribir como participante (senderKind).
model Conversation {
  id        String   @id @default(cuid())
  orgId     String
  memberId  String   @unique
  createdAt DateTime @default(now())

  organization Organization  @relation(fields: [orgId], references: [id])
  member       Member        @relation(fields: [memberId], references: [id])
  messages     ChatMessage[]

  @@index([orgId])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderKind     String // "MEMBER" | "TRAINER" | "AI" | "DIRECTION"
  senderUserId   String?
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User?        @relation(fields: [senderUserId], references: [id])

  @@index([conversationId])
}
